{
  "swagger": "2.0",
  "info": {
    "title": "Sales Channel Webhooks API",
    "version": "v2"
  },
  "tags": [
    {
      "name": "SalesChannelService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/ingestion/initiate": {
      "post": {
        "operationId": "SalesChannelService_InitiateIngestion",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/listing_apiInitiateIngestionResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googlerpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/listing_apiInitiateIngestionRequest"
            }
          }
        ],
        "tags": [
          "SalesChannelService"
        ]
      }
    },
    "/v2/storefront/status/{storefrontId}": {
      "get": {
        "summary": "StorefrontStatus returns the current status of a storefront\nas a series of diagnostic checks",
        "operationId": "SalesChannelService_StorefrontStatus",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/listing_apiStorefrontStatusResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googlerpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "storefrontId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "SalesChannelService"
        ]
      }
    }
  },
  "definitions": {
    "StorefrontStatusResponseCheck": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "state": {
          "$ref": "#/definitions/StorefrontStatusResponseCheckState"
        },
        "stateShortDescription": {
          "type": "string"
        },
        "details": {
          "type": "string"
        }
      }
    },
    "StorefrontStatusResponseCheckState": {
      "type": "string",
      "enum": [
        "CHECK_STATE_UNSPECIFIED",
        "CHECK_STATE_PASS",
        "CHECK_STATE_FAIL",
        "CHECK_STATE_WARNING"
      ],
      "default": "CHECK_STATE_UNSPECIFIED",
      "title": "CheckState represents the result state of a diagnostic check"
    },
    "googlerpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "listing_apiInitiateIngestionRequest": {
      "type": "object",
      "properties": {
        "storefrontId": {
          "type": "string"
        },
        "skus": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "autoApplyIngestionPlan": {
          "type": "boolean"
        }
      },
      "title": "InitiateIngestionRequest is the request for the InitiateIngestion RPC"
    },
    "listing_apiInitiateIngestionResponse": {
      "type": "object",
      "title": "InitiateIngestionResponse is the response for the InitiateIngestion RPC"
    },
    "listing_apiStorefrontStatusResponse": {
      "type": "object",
      "properties": {
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StorefrontStatusResponseCheck"
          }
        }
      },
      "title": "StorefrontStatusResponse contains the results of all diagnostic checks"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    }
  }
}
