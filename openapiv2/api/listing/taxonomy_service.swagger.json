  "definitions": {
    "AttributeSpecClassification": {
      "type": "string",
      "enum": [
        "CLASSIFICATION_UNSPECIFIED",
        "CLASSIFICATION_PRODUCT",
        "CLASSIFICATION_INVENTORY",
        "CLASSIFICATION_PRICING",
        "CLASSIFICATION_LOGISTICS",
        "CLASSIFICATION_IDENTIFIER"
      ],
      "default": "CLASSIFICATION_UNSPECIFIED",
      "title": "Classification specifies whether this AttributeSpec relates to\nProduct, Inventory, or Pricing data"
    },
    "AttributeSpecLevel": {
      "type": "string",
      "enum": [
        "LEVEL_UNSPECIFIED",
        "LEVEL_LISTING",
        "LEVEL_VARIANT"
      ],
      "default": "LEVEL_UNSPECIFIED",
      "title": "Level specifies whether this AttributeSpec should be rendered\non the Listing-level or the Variant-level"
    },
    "QualityAttributeSpecUsage": {
      "type": "string",
      "enum": [
        "USAGE_UNSPECIFIED",
        "USAGE_REQUIRED",
        "USAGE_RECOMMENDED"
      ],
      "default": "USAGE_UNSPECIFIED",
      "title": "Usage indicates if the spec is required or just recommended"
    },
    "listing_apiAttributeSpec": {
      "type": "object",
      "properties": {
        "attributeSpecId": {
          "type": "string",
          "title": "This is the ID that will be used when retrieving listing data or submitting\nerror to Zentail. It should reflect whatever meaningful identifier can be\nused to ingest this attribute into your system. In the past we have seen it\nbe a numeric identifier or an xpath/jsonpath string"
        },
        "displayName": {
          "type": "string",
          "description": "Human-readable name for the attribute. Used for display purposes only."
        },
        "type": {
          "$ref": "#/definitions/listing_apiAttributeSpecType"
        },
        "validValues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "If the type is SELECT or MULTI_SELECT, provide the valid values here"
        },
        "validUnits": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "title": "If the type is NUMERIC_WITH_UNITS, provide the valid units here"
        },
        "unit": {
          "type": "string",
          "title": "Optional, used to specify the unit of the numeric value when the type is\nTYPE_NUMERIC This will allow Zentail to convert values with units in\nZentail to a single numeric value if your channel does not support units"
        },
        "level": {
          "$ref": "#/definitions/AttributeSpecLevel"
        },
        "classification": {
          "$ref": "#/definitions/AttributeSpecClassification"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "AttributeSpec is the specification of an attribute within a Category on your\nchannel."
    },
    "listing_apiAttributeSpecType": {
      "type": "string",
      "enum": [
        "TYPE_UNSPECIFIED",
        "TYPE_TEXT",
        "TYPE_SELECT",
        "TYPE_NUMERIC",
        "TYPE_NUMERIC_WITH_UNITS",
        "TYPE_MULTI_TEXT",
        "TYPE_MULTI_SELECT",
        "TYPE_MONEY"
      ],
      "default": "TYPE_UNSPECIFIED",
      "title": "Type specifies what form the related attribute should be rendered into"
    },
    "listing_apiCategory": {
      "type": "object",
      "properties": {
        "channelCategoryId": {
          "type": "string",
          "title": "The ID of this category defined by your system"
        },
        "parentCategoryId": {
          "type": "string",
          "title": "References another Category's id as this Category's parent, can be empty\nfor top-level categories"
        },
        "displayName": {
          "type": "string",
          "title": "A user-friendly name for the category"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "Category provides a (usually) high-level classification for a Listing.\nCategories can be arranged in a tree-like structure with parent and\nchild categories. The category will often be a crucial piece of\ninformation about how the data is structured when sending to the\nchannel. For example, on Amazon it dictates which path to take down\nthe XSD when constructing feed messages. An example category on Amazon\nwould be Clothing."
    },
    "listing_apiCreateCategoryRequest": {
      "type": "object",
      "properties": {
        "category": {
          "$ref": "#/definitions/listing_apiCategory"
        }
      },
      "title": "CreateCategoryRequest will create a new Category"
    },
    "listing_apiCreateCategoryResponse": {
      "type": "object",
      "properties": {
        "category": {
          "$ref": "#/definitions/listing_apiCategory"
        }
      },
      "title": "CreateCategoryResponse returns the newly created Category"
    },
    "listing_apiCreateProductTypeRequest": {
      "type": "object",
      "properties": {
        "productType": {
          "$ref": "#/definitions/listing_apiProductType"
        }
      },
      "title": "CreateProductTypeRequest is used to create a new ProductType"
    },
    "listing_apiCreateProductTypeResponse": {
      "type": "object",
      "properties": {
        "productType": {
          "$ref": "#/definitions/listing_apiProductType"
        }
      },
      "title": "CreateProductTypeResponse returns the newly created ProductType"
    },
    "listing_apiDeleteAttributeSpecResponse": {
      "type": "object",
      "title": "DeleteAttributeSpecResponse is returned after deleting an AttributeSpec"
    },
    "listing_apiDeleteProductTypeResponse": {
      "type": "object",
      "title": "DeleteProductTypeResponse is returned by the DeleteProduct type action"
    },
    "listing_apiDeleteQualityAttributeSpecResponse": {
      "type": "object",
      "title": "DeleteQualityAttributeSpecResponse is returned after deleting a\nQualityAttributeSpec"
    },
    "listing_apiListCategoriesResponse": {
      "type": "object",
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/listing_apiCategory"
          }
        }
      },
      "title": "ListCategoriesResponse contains the list of categories"
    },
    "listing_apiListProductTypesResponse": {
      "type": "object",
      "properties": {
        "productTypes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/listing_apiProductType"
          }
        }
      },
      "title": "ListProductTypesResponse contains all of the product types returned"
    },
    "listing_apiListQualityAttributeSpecsResponse": {
      "type": "object",
      "properties": {
        "qualityAttributeSpecs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/listing_apiQualityAttributeSpec"
          }
        }
      },
      "title": "ListQualityAttributeSpecsResponse contains all of the quality attribute specs\nin the requested ProductType"
    },
    "listing_apiProductType": {
      "type": "object",
      "properties": {
        "categoryId": {
          "type": "string"
        },
        "channelProductTypeId": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "ProductType are detailed classifications dictated by the channel.\nThey should be at least as specific as the Category.\nGenerally they should be more specific than the Category.\nProduct Types are used to specify which attributes are required and\nrecommended for a given Listing.\nIf this is not a concept in your system, you should create a product type for\neach category."
    },
    "listing_apiQualityAttributeSpec": {
      "type": "object",
      "properties": {
        "attributeSpecId": {
          "type": "string"
        },
        "usage": {
          "$ref": "#/definitions/QualityAttributeSpecUsage"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "description": "QualityAttributeSpec provides a connection between a ProductType\nand an AttributeSpec. If a Quality Attribute Spec exists for an\nAttributeSpec in a particular ProductType, that Spec is either\nRecommended or Required in that ProductType (and the Quality\nAttribute Spec will indicate which it is)."
    },
    "listing_apiUpdateCategoryRequest": {
      "type": "object",
      "properties": {
        "category": {
          "$ref": "#/definitions/listing_apiCategory"
        }
      },
      "title": "UpdateCategoryRequest will update the category with the matching\nchannel_category_id and parent_category_id"
    },
    "listing_apiUpdateCategoryResponse": {
      "type": "object",
      "properties": {
        "category": {
          "$ref": "#/definitions/listing_apiCategory"
        }
      },
      "title": "UpdateCategoryResponse will return the updated category"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  }
}
