            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "categoryId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "attributeSpec": {
                  "$ref": "#/definitions/listing_apiAttributeSpec"
                }
              },
              "title": "UpdateAttributeSpecRequest is used to update an existing AttributeSpec"
            }
          }
        ],
        "tags": [
          "TaxonomyService"
        ]
      }
    },
