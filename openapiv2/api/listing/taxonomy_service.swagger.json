            }
          }
        },
        "parameters": [
          {
            "name": "categoryId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "attributeSpec": {
                  "$ref": "#/definitions/listing_apiAttributeSpec"
                }
              },
              "title": "CreateAttributeSpecRequest is used to create a new AttributeSpec"
            }
          }
        ],
        "tags": [
          "TaxonomyService"
        ]
      },
      "put": {
        "summary": "UpdateAttributeSpec will update the AttributeSpec with the given\ncategory_id and attribute_spec_id",
